#Q1

import csv

data = []
with open('training.csv') as csvfile:
    reader = csv.reader(csvfile)
    next(reader)
    for row in reader:
        data.append(row)

hypothesis = data[0][:-1]

for row in data:
    if row[-1] == "Yes":
        for i in range(len(hypothesis)):
            if hypothesis[i] != row[i]:
                hypothesis[i] = '?'

print("Most Specific Hypothesis:")
print(hypothesis)
